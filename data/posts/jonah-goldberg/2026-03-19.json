      "timestamp": "2026-03-19T11:53:51+00:00",
      "type": "tweet"
    },
    {
      "voiceId": "jonah-goldberg",
      "voiceName": "Jonah Goldberg",
      "platform": "x",
      "text": "\u201cGood morning. It\u2019s Thursday. Stay focused on the mission. Or nap. Napping is also good. Also, I love you.\u201d",
