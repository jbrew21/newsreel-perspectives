      "voiceName": "Scott Galloway",
      "platform": "bluesky",
      "text": "\"Sit, Dawg\"\n\n@karaswisher.bsky.social puts @profgalloway.com in his place at #SWSW",
      "sourceUrl": "https://bsky.app/profile/profgalloway.com/post/3mh4w7nudas2b",
