    },
    {
      "voiceId": "stephen-a-smith",
      "voiceName": "Stephen A. Smith",
      "platform": "x",
      "text": "I'm LIVE right now and I'm taking calls until 3PM on @MadDogRadio! \n\u260e\ufe0f (888-623-3646)\n\ud83c\udfa7 sxm.app.link/SASonSXM",
