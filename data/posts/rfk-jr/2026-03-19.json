    },
    {
      "voiceId": "rfk-jr",
      "voiceName": "Robert F. Kennedy Jr.",
      "platform": "x",
      "text": "Happy President\u2019s Day!",
      "sourceUrl": "https://x.com/RobertKennedyJr/status/2023474448381403378",
      "timestamp": "2026-02-16T19:07:57+00:00",
      "type": "tweet"
    },
    {
      "voiceId": "rfk-jr",
      "voiceName": "Robert F. Kennedy Jr.",
      "platform": "x",
      "text": "You own my heart. You are my Universe. Happy Valentines Day @CherylHines",
      "sourceUrl": "https://x.com/RobertKennedyJr/status/2022723627049947475",
      "timestamp": "2026-02-14T17:24:27+00:00",
      "type": "tweet"
    },
    {
      "voiceId": "rfk-jr",
      "voiceName": "Robert F. Kennedy Jr.",
      "platform": "x",
      "text": "Playing catch with Uncle Jack, Hickory Hill.",
      "sourceUrl": "https://x.com/RobertKennedyJr/status/2021341986075312628",
      "timestamp": "2026-02-10T21:54:18+00:00",
      "type": "tweet"
    },
    {
      "voiceId": "rfk-jr",
      "voiceName": "Robert F. Kennedy Jr.",
      "platform": "x",
      "text": "Rest in Peace Bob Weir. Thank you for all the years of support in the environment wars and thank you for your friendship. \n\n\u201cFare-thee-well now\nLet your life proceed by its own design\nNothing to tell now\nLet the words be yours, I'm done with mine\u201d",
      "sourceUrl": "https://x.com/RobertKennedyJr/status/2010394988287558063",
      "timestamp": "2026-01-11T16:54:51+00:00",
      "type": "tweet"
    },
    {
      "voiceId": "rfk-jr",
      "voiceName": "Robert F. Kennedy Jr.",
      "platform": "x",
      "text": "Caution! Do not take dietary advice from this guy\n\n\n\n\nJD Vance (@JDVance)\n\nhey @SecKennedy this new food pyramid is solid but you forgot to include one dietary staple:\n\n\n\n\n\n\u2014 https://nitter.net/JDVance/status/2009265176617329034#m",
      "sourceUrl": "https://x.com/RobertKennedyJr/status/2009281182161068521",
      "timestamp": "2026-01-08T15:08:59+00:00",
      "type": "tweet"
    },
    {
      "voiceId": "rfk-jr",
      "voiceName": "Robert F. Kennedy Jr.",
      "platform": "x",
      "text": "so grateful for Christmas in the rockies with my children\u2764\ufe0f kyra, finnbar and aidan! ... and my friends Diplo &amp; Sec Howard Lutnick and their families ! Merry Christmas everybody \u2764\ufe0f",
      "sourceUrl": "https://x.com/RobertKennedyJr/status/2004325059478147423",
      "timestamp": "2025-12-25T22:55:07+00:00",
      "type": "tweet"
    },
